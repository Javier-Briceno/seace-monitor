          "name": "Postgres account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const items = $input.all();\n\n// Agrupar por licitacion_id\nconst grupos = {};\nfor (const item of items) {\n  const id = item.json.licitacion_id;\n  if (!grupos[id]) grupos[id] = [];\n  grupos[id].push(item.json);\n}\n\n// Consolidar cada grupo\nconst resultado = [];\nfor (const [licitacion_id, documentos] of Object.entries(grupos)) {\n  resultado.push({\n    json: {\n      licitacion_id: parseInt(licitacion_id),\n      documentos_analizados: documentos.length,\n      truncated: documentos.some(d => d.truncated),\n      total_input_tokens: documentos.reduce((sum, d) => sum + (d.input_tokens || 0), 0),\n      total_output_tokens: documentos.reduce((sum, d) => sum + (d.output_tokens || 0), 0),\n      tipo_documento: documentos.map(d => d.analisis?.tipo_documento).filter(Boolean).join(', '),\n      valor_referencial: documentos.map(d => d.analisis?.valor_referencial).find(v => v?.monto !== null) ?? null,\n      plazo_ejecucion: documentos.map(d => d.analisis?.plazo_ejecucion).find(v => v?.dias !== null) ?? null,\n      experiencia_requerida: documentos.map(d => d.analisis?.experiencia_requerida).find(v => v?.monto_minimo !== null || v?.anios !== null) ?? null,\n      requisitos_habilitacion: documentos.map(d => d.analisis?.requisitos_habilitacion).find(v => v?.valor !== null) ?? null,\n      resumen_ejecutivo: documentos.map(d => d.analisis?.resumen_ejecutivo).filter(Boolean).join(' | ')\n    }\n  });\n}\n\nreturn resultado;"
      },
