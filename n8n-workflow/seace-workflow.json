    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const response = $json;\nconst textBlock = response.content?.find(b => b.type === 'text');\n\nif (!textBlock) {\n  return {\n    json: {\n      licitacion_id: $(\"Filter\").item.json.licitacion_id,\n      documento_uuid: $(\"Filter\").item.json.uuid,\n      analisis: null,\n      error: 'No text block in response',\n      stop_reason: response.stop_reason,\n      input_tokens: response.usage?.input_tokens\n    }\n  };\n}\n\nlet analisis = null;\nlet parseError = null;\n\ntry {\n  const clean = textBlock.text.replace(/```json|```/g, '').trim();\n  analisis = JSON.parse(clean);\n} catch (e) {\n  parseError = e.message;\n}\n\nreturn {\n  json: {\n    licitacion_id: $(\"Filter\").item.json.licitacion_id,\n    documento_uuid: $(\"Filter\").item.json.uuid,\n    analisis,\n    stop_reason: response.stop_reason,\n    input_tokens: response.usage?.input_tokens,\n    output_tokens: response.usage?.output_tokens,\n    truncated: response.stop_reason === 'max_tokens',\n    parse_error: parseError\n  }\n};"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2672,
        1760
      ],
      "id": "9dc8a5d0-bed7-4a72-ae33-a067f3981c0b",
      "name": "Format Answer"
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT id FROM licitaciones\nWHERE nomenclatura = $1\n  AND entidad = $2\n  AND fecha_publicacion = $3 \nUNION ALL \nSELECT NULL WHERE NOT EXISTS (\n  SELECT 1 FROM licitaciones \n  WHERE nomenclatura = $1\n    AND entidad = $2\n    AND fecha_publicacion = $3 \n)",
        "options": {
          "queryReplacement": "={{ $json.items.nomenclatura }}, {{ $json.items.entidad }}, {{ $json.items.fecha_publicacion ? new Date($json.items.fecha_publicacion.split(' ')[0].split('/').reverse().join('-') + 'T' + ($json.items.fecha_publicacion.split(' ')[1] || '00:00') + ':00').toISOString() : null }}"
        }
      },
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.6,
      "position": [
        16,
        1680
      ],
      "id": "c9e14d63-160e-4697-aff3-def125afb887",
      "name": "Get ID of existing Items",
      "credentials": {
